;; The cert-manager tool package. A casebook depends on it by subpath:
;;   {:deps {io.github.metio/gumshoe {:git/tag "…" :deps/root "tools/certmanager"}}}
;; and lists gumshoe.tools.certmanager under env.edn :plugins to fill the :tls scope
;; and teach the wizard the :cert-manager capability.
{:paths ["libraries" "runbooks"]
 :deps {io.github.metio/gumshoe {:local/root "../.."}}}
