;; The ceph tool package (cephadm-over-SSH cluster management). A casebook depends
;; on it by subpath:
;;   {:deps {io.github.metio/gumshoe {:git/tag "…" :deps/root "tools/ceph"}}}
;; The books use the ceph lib directly; list gumshoe.tools.ceph under env.edn
;; :plugins to also get the ceph cluster-log tailer during storage resizes.
{:paths ["libraries" "runbooks" "playbooks"]
 :deps {io.github.metio/gumshoe-core {:local/root "../.."}}}
