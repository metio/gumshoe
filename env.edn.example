;; Host-specific configuration. Copy this to env.edn (gitignored) and adjust it
;; for your machine, or run `bb runbooks/setup/init.clj` to build it
;; interactively. Every key is optional; anything absent keeps the default
;; behavior. env.edn is searched for in this directory, then
;; $XDG_CONFIG_HOME/operational-bookstore/env.edn, then
;; ~/.config/operational-bookstore/env.edn - or point OPERATIONAL_BOOKSTORE_ENV
;; at a file directly.

;; ---------------------------------------------------------------------------
;; Environments (recommended)
;;
;; Related infrastructure travels together: the staging Kubernetes cluster, the
;; staging ceph cluster, and the staging VPN are one bundle. Declare each bundle
;; as a named environment and tie it to a Kubernetes cluster with :select. The
;; active environment is chosen by the kubectl context you are already on - so
;; selecting the cluster selects its ceph host and VPN too. Switch your context
;; to staging and a storage resize there tails staging's ceph over staging's VPN;
;; switch to production and it tails production's. Nothing to remember, no flag.
;;
;; Override the auto-selection with OPERATIONAL_BOOKSTORE_ENVIRONMENT=<name> when
;; you are not anchored to a kubectl context. Values fall back to :defaults.

{:environments
 {:production {:select {:kubernetes-cluster "kube.example.org"}
               ;; What this cluster can do, as opt-in labels. A book declares the
               ;; capabilities it needs (:cluster-capabilities [:cnpg]) and only
               ;; runs where they are present. The setup wizard fills these in by
               ;; probing the cluster; add or trim by hand any time. A cluster
               ;; that declares no :capabilities is not capability-gated - books
               ;; run on it as long as it is a known cluster.
               :capabilities [:flux :cert-manager :gateway-api :cnpg :prometheus-operator :calico]
               ;; The VPN interface that must be up before books reach private
               ;; hosts. Its mere presence is taken as "connected" (wg-quick
               ;; only creates the interface while the tunnel is up).
               :vpn {:interface "wg0"}
               ;; Ceph mgr/admin hosts. When set, storage-resize books also tail
               ;; the ceph cluster log over SSH while they wait (gated on the VPN
               ;; above), so a resizer error surfaces live.
               :ceph {:mgr-hosts ["mgr-1.example.org"]}
               ;; Service inputs the detectives need, per environment. Each is
               ;; also settable with a flag (--domain, --host, --namespace,
               ;; --frontend), which overrides env.edn for a one-off. Run the
               ;; setup wizard again after an upgrade and it asks only for the
               ;; inputs a new release added.
               ;; :matrix is the homeserver the DETECTIVE investigates
               ;; (.well-known, delegation) - point it at whatever server you are
               ;; debugging, even someone else's.
               :matrix {:domain "example.org"
                        :host "synapse.example.org"}
               ;; :announce is the list of announcers a CHANGE is posted to - one
               ;; change can go to several places at once. Each has a :type; the
               ;; built-ins are :matrix and :webhook (Slack/Discord/Mattermost).
               ;; A plugin (a git dep listed in :plugins) can add more types
               ;; (:irc, :mastodon, ...). Deliberately separate from :matrix: you
               ;; announce on your own server while investigating another. No
               ;; announcers → the change is not announced (a warning), never
               ;; blocked.
               :announce [{:type :matrix
                           :homeserver "https://synapse.example.org"
                           :room "%21DnIjxbPfpKJMVigUwx:example.org"
                           :as "@you:example.org"
                           :token-secret "matrix/announcement-bot"}
                          {:type :webhook
                           :url "https://hooks.slack.com/services/T000/B000/xxxx"
                           :format :slack}]
               :loki {:namespace "loki"}
               ;; Observability service endpoints the metrics/dashboard books
               ;; default to (each is also overridable with a flag).
               :grafana {:url "https://grafana.example.org"}
               :prometheus {:url "https://prometheus.example.org"
                            :rules-directory "/path/to/prometheus/alert-rules"}
               :alertmanager {:host "alertmanager.example.org"}
               ;; DNS + mail detective targets - the zone, servers, and the names
               ;; the DNS detective checks resolve identically everywhere.
               :dns {:zone "example.org"
                     :server "dns.example.org"
                     :probes ["dns.example.org" "www.example.org"]}
               :mail {:domain "example.org" :host "mail.example.org"}
               :opennebula {:frontend "one-1.example.org"}
               ;; Cluster-admins you have vetted, so the RBAC detective stops
               ;; flagging them and shows only surprising access. List a subject
               ;; exactly ("Group platform-admins", "ServiceAccount kube-system/x")
               ;; or glob a whole namespace of operators ("ServiceAccount
               ;; flux-system/*"). Humans (User/Group) left off this list stay
               ;; critical - a person with cluster-admin is worth re-confirming.
               :rbac {:expected-cluster-admins ["ServiceAccount kube-system/*"
                                                "ServiceAccount flux-system/*"]}}

  :staging {:select {:kubernetes-cluster "kube.staging.example.org"}
            :vpn {:interface "wg-staging"}
            :ceph {:mgr-hosts ["mgr-1.staging.example.org"]}
            :matrix {:domain "staging.example.org" :host "synapse.staging.example.org"}
            :loki {:namespace "loki"}}}

 ;; Shared fallback for any environment that does not set a key itself.
 :defaults {:vpn {:interface "wg0"}}

 ;; Known clusters are taken from the environments' :select above. On a flat
 ;; config (no :environments) list them here so cluster-requiring books can still
 ;; verify you are on one you set up. Empty/unset means no allow-list is enforced.
 ;;   :clusters ["kube.example.org"]

 ;; ---------------------------------------------------------------------------
 ;; Plugins (top-level) - namespaces to load, which register into gumshoe's seams
 ;; (announcers, detectives, capability detectors, tool support, summary
 ;; providers). Their code is on the classpath via the dep graph (this casebook's
 ;; own libraries/ and gumshoe's deps); listing a namespace here is what triggers
 ;; its registration. A failed plugin load warns, never fatal. See
 ;; examples/example/plugin.clj for a worked plugin.
 ;;   :plugins [acme.announce.irc mycasebook.detectors]

 ;; ---------------------------------------------------------------------------
 ;; HedgeDoc (top-level) - where read-only scans can be shared as a pad. When
 ;; set, a scan offers to create a note directly and prints its URL; unset, it
 ;; copies the findings as Markdown to your clipboard to paste into a pad or a
 ;; ticket instead.
 ;;   :hedgedoc {:url "https://pad.example.org"}

 ;; ---------------------------------------------------------------------------
 ;; Secrets (top-level, machine-specific - not per environment)
 ;;
 ;; How to read a secret from your password manager. gopass is the default; set
 ;; :secrets to use another (pass, 1Password, Bitwarden, Vault, ...). {path} is
 ;; the secret path a book asks for; {field} a named field within it. This makes
 ;; a different CLI, its own flags, and even a different path structure just
 ;; configuration - no book changes.
 ;;
 ;;   gopass (default, shown for reference):
 ;;   :secrets {:password ["gopass" "show" "--password" "{path}"]
 ;;             :field    ["gopass" "show" "{path}" "{field}"]
 ;;             :search   ["gopass" "search" "{path}"]}
 ;;
 ;;   1Password, mapping the book's path into your vault structure:
 ;;   :secrets {:password ["op" "read" "op://ops/{path}/password"]
 ;;             :field    ["op" "read" "op://ops/{path}/{field}"]
 ;;             :search   ["op" "item" "list" "--format=json"]}
 ;;
 ;;   pass (first line is the password):
 ;;   :secrets {:password ["pass" "show" "{path}"]
 ;;             :field    ["pass" "show" "{path}/{field}"]
 ;;             :search   ["pass" "find" "{path}"]}
 }

;; ---------------------------------------------------------------------------
;; Flat form (simple single-machine case)
;;
;; If you only ever operate one environment, skip the nesting entirely - a flat
;; map is still valid and is read as-is:
;;
;; {:vpn  {:interface "wg0"}
;;  :ceph {:mgr-hosts ["mgr-1.example.org"]}}
