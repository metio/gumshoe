;; gumshoe as a tools.deps library. A casebook depends on it and gets the engine
;; (gumshoe.* on the classpath) AND the built-in books - runbooks/playbooks/
;; firebooks are on :paths too, so a dependent's book discovery finds them from
;; the classpath alongside its own.
;;
;;   ;; casebook bb.edn
;;   {:deps  {io.github.metio/gumshoe {:git/tag "2026.7.5" :git/sha "…"}}
;;    :paths ["libraries" "runbooks" "playbooks" "firebooks"]}
;;
;; babashka resolves git deps via tools.deps, which needs a JVM (the flake's
;; devShell provides it); the resolution is cached under ~/.gitlibs afterwards.
{:paths ["libraries" "runbooks" "playbooks" "firebooks"]}
