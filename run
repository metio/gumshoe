;; Launch any single book by fuzzy search.
;; A thin wrapper over gumshoe.main so the same door works from this repo and from
;; a casebook's bb.edn :tasks. All flags pass through.

(require '[gumshoe.main :as main])

(System/exit (main/run *command-line-args*))
